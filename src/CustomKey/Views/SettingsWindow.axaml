<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CustomKey.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:ui="using:FluentAvalonia.UI.Controls"
        x:Class="CustomKey.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="455"
        WindowStartupLocation="CenterScreen"
        MinHeight="455" MinWidth="760" Height="455" Width="760"
		Title="{Binding [TradSettings]}"
        Background="{DynamicResource BackgroundColor}">
	<Design.DataContext>
		<vm:SettingsWindowViewModel/>
	</Design.DataContext>

	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key='Default'>
					<SolidColorBrush x:Key="BackgroundColor" Color="#f3f3f3"/>
				</ResourceDictionary>
				<ResourceDictionary x:Key='Dark'>
					<SolidColorBrush x:Key="BackgroundColor" Color="#202020"/>
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>
		</ResourceDictionary>
	</Window.Resources>

	<ScrollViewer>
		<StackPanel Margin="15" Spacing="7">
			<!-- Header -->
			<Grid>
				<Border CornerRadius="7" Height="110" Background="Transparent" ClipToBounds="True">
					<Image x:Name="CurrentBg" Stretch="UniformToFill"/>
				</Border>
				<TextBlock Text="{Binding [TradSettings]}" FontSize="45" FontWeight="Bold" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
			</Grid>
			
			<!-- App Theme -->
			<ui:FASettingsExpander Header="{Binding [TradTheme]}" IconSource="DarkTheme" Description="{Binding [TradThemeDesc]}">
				<ui:FASettingsExpander.Footer>
					<ComboBox ItemsSource="{Binding AppThemes}" SelectedValue="{Binding CurrentAppTheme}" MinWidth="150" />
				</ui:FASettingsExpander.Footer>
			</ui:FASettingsExpander>

			<!-- Background image -->
			<ui:FASettingsExpander Header="{Binding [TradKeyboardBg]}" IconSource="Image" Description="{Binding [TradKeyboardBgDesc]}" IsExpanded="False">
				<ui:FASettingsExpanderItem>
					<CheckBox x:Name="CustomBgCheckBox" Content="{Binding [TradKeyboardBgCheckbox]}" IsChecked="{Binding CustomBg, Mode=TwoWay}" HorizontalAlignment="Right" />
				</ui:FASettingsExpanderItem>
				<ui:FASettingsExpanderItem IsVisible="{Binding IsChecked, ElementName=CustomBgCheckBox}">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/> <!-- Text -->
							<RowDefinition Height="Auto"/> <!-- Images -->
							<RowDefinition Height="Auto"/> <!-- Buttons -->
						</Grid.RowDefinitions>

						<TextBlock Grid.Row="0" Text="{Binding [TradKeyboardBgYour]}" Margin="5 0 0 10"/>

						<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Spacing="10" Cursor="Hand">
							<Border CornerRadius="4" Width="120" Height="68" ClipToBounds="True">
								<Image x:Name="CustomBg1" Stretch="UniformToFill"/>
							</Border>
							<Border CornerRadius="4" Width="120" Height="68" ClipToBounds="True">
								<Image x:Name="CustomBg2" Stretch="UniformToFill"/>
							</Border>
						</StackPanel>
						
						<Button Grid.Row="2" x:Name="UploadImageButton" Content="{Binding [TradKeyboardBgUpload]}" HorizontalAlignment="Left" Margin="0 10 0 0"/>
					</Grid>
				</ui:FASettingsExpanderItem>
				
				<!-- Note : All images include internal images are loaded from the C# with DecodeToWith in order to reduce memory usage drasticly -->
				<ui:FASettingsExpanderItem IsVisible="{Binding IsChecked, ElementName=CustomBgCheckBox}">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/> <!-- Text -->
							<RowDefinition Height="Auto"/> <!-- Images -->
						</Grid.RowDefinitions>

						<TextBlock Grid.Row="0" Text="{Binding [TradKeyboardBgPreset]}" Margin="5 0 0 10"/>

						<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Spacing="10" Cursor="Hand">
							<Border CornerRadius="4" Width="120" Height="68" ClipToBounds="True">
								<Image x:Name="CurvesImage" Stretch="UniformToFill"/>
							</Border>
							<Border CornerRadius="4" Width="120" Height="68" ClipToBounds="True">
								<Image x:Name="GeoImage" Stretch="UniformToFill"/>
							</Border>
							<Border CornerRadius="4" Width="120" Height="68" ClipToBounds="True">
								<Image x:Name="GradientImage" Stretch="UniformToFill"/>
							</Border>
							<Border CornerRadius="4" Width="120" Height="68" ClipToBounds="True">
								<Image x:Name="RedImage" Stretch="UniformToFill"/>
							</Border>
						</StackPanel>
					</Grid>
				</ui:FASettingsExpanderItem>
			</ui:FASettingsExpander>

			<!-- App Languages -->
			<ui:FASettingsExpander Header="{Binding [TradLanguages]}" IconSource="World" Description="{Binding [TradLanguageChange]}">
				<ui:FASettingsExpander.Footer>
					<ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding Language, Mode=TwoWay}" MinWidth="150"/>
				</ui:FASettingsExpander.Footer>
			</ui:FASettingsExpander>
			
			<!-- Layouts manager -->
			<ui:FASettingsExpander Header="{Binding [TradLayouts]}" IconSource="Keyboard" Description="{Binding [TradLayoutsDesc]}" IsExpanded="True">
				<ListBox x:Name="Layout">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Grid ColumnDefinitions="*,Auto,Auto">
								<TextBlock Text="{Binding}" VerticalAlignment="Center"/>

								<Button Grid.Column="1" Click="EditLayoutClick">
									<ui:FASymbolIcon Symbol="Edit"/>
								</Button>

								<Button Grid.Column="2" Click="DeleteLayoutClick" Margin="5">
									<ui:FASymbolIcon Symbol="Delete"/>
								</Button>
							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
				<Button Content="{Binding [TradLayoutsCreate]}" Click="CreateLayoutClick"/>
			</ui:FASettingsExpander>
			
			<!-- About -->
			<ui:FASettingsExpander Header="{Binding [TradAbout]}" IconSource="M2 14C2 20.6274 7.37258 26 14 26C20.6274 26 26 20.6274 26 14C26 7.37258 20.6274 2 14 2C7.37258 2 2 7.37258 2 14ZM15.25 8C15.25 8.69036 14.6904 9.25 14 9.25C13.3096 9.25 12.75 8.69036 12.75 8C12.75 7.30964 13.3096 6.75 14 6.75C14.6904 6.75 15.25 7.30964 15.25 8ZM14 11C14.5523 11 15 11.4477 15 12L15 20C15 20.5523 14.5523 21 14 21C13.4477 21 13 20.5523 13 20L13 12C13 11.4477 13.4477 11 14 11Z">
				<ui:FASettingsExpanderItem>
					<StackPanel Spacing="2">
						<TextBlock Text="{Binding [TradDesignedBy]}" />
						<TextBlock Text="{Binding [TradAboutApp]}" />
						<TextBlock Text="{Binding [TradAboutBuild]}" />
					</StackPanel>
				</ui:FASettingsExpanderItem>
				<ui:FASettingsExpanderItem>
					<HyperlinkButton NavigateUri="https://github.com/leo-t-88/customkey" HorizontalAlignment="Stretch" Padding="0">
						<Grid ColumnDefinitions="*,Auto">
							<TextBlock Text="{Binding [TradAboutReport]}" Grid.Column="0"/>
							<ui:FASymbolIcon Symbol="Open" Grid.Column="1"/>
						</Grid>
					</HyperlinkButton>
				</ui:FASettingsExpanderItem>
				<ui:FASettingsExpanderItem Content="{Binding VersionNumber}"/>
			</ui:FASettingsExpander>
		</StackPanel>
	</ScrollViewer>
</Window>